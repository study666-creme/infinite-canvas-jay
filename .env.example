# Local canvas-agent. Pass this file with your process manager or shell;
# the runtime does not automatically load the repository root .env file.
PORT=17371
CANVAS_AGENT_HOST=127.0.0.1
CANVAS_AGENT_PUBLIC_URL=
CANVAS_AGENT_TOKEN=
CANVAS_AGENT_WORKSPACE=
CANVAS_AGENT_REPO_ROOTS=
# Optional local-only creative extension. Set to off to disable auto-discovery.
CANVAS_AGENT_PRIVATE_CONTEXT=auto
CANVAS_AGENT_PRIVATE_INSTRUCTIONS=
CANVAS_AGENT_PRIVATE_KNOWLEDGE_REPORT=

# Web server routes.
PROMPT_HUB_API_BASE=https://api.prompt-hubs.com
NEW_API_BASE_URL=https://newapi.prompt-hubs.com
NEW_API_API_KEY=
